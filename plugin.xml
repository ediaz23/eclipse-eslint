<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <extension
         id="builder"
         name="ESLint Builder"
         point="org.eclipse.core.resources.builders">
      <builder
            hasNature="true">
         <run
               class="com.eclipse.eslint.builder.ESLintBuilder">
         </run>
      </builder>
   </extension>

   <extension
         id="nature"
         name="ESLint Nature"
         point="org.eclipse.core.resources.natures">
      <runtime>
         <run
               class="com.eclipse.eslint.builder.ESLintNature">
         </run>
      </runtime>
      <builder
            id="com.eclipse.eslint.builder.builder">
      </builder>
   </extension>

   <extension
         id="problem"
         name="ESLint Problem"
         point="org.eclipse.core.resources.markers">
      <super
            type="org.eclipse.core.resources.problemmarker">
      </super>
      <persistent
            value="true">
      </persistent>
   </extension>

</plugin>